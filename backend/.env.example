# Backend Environment Variables
DATABASE_URL="postgresql://user:password@localhost:5432/inner_cosmos_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Google Cloud Storage
GCS_PROJECT_ID="your-gcp-project-id"
GCS_BUCKET_NAME="inner-cosmos-invoices"
GCS_KEY_FILE="./gcs-service-account.json"

# App
PORT=3001
NODE_ENV=production
FRONTEND_STORE_URL="https://yourdomain.com"
FRONTEND_ERP_URL="https://erp.yourdomain.com"

# Company info for invoices
COMPANY_NAME="Inner Cosmos"
COMPANY_ADDRESS="123 Business Street, City, Country"
COMPANY_EMAIL="billing@innercosmos.com"
COMPANY_PHONE="+1 (555) 000-0000"
